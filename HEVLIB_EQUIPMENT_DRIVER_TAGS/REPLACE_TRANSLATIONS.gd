			"string": "Drone Mount",
			"version_hash": 3658239856
		},
		"SLOT_MAIN_LARGE": {
			"string": "Large Main Propulsion",
			"version_hash": 4168458352
		},
		"SLOT_RCS_LARGE": {
			"string": "Large Reaction Control System",
			"version_hash": 4107040235
		},
		"IOE_MOD_DESCRIPTION": {
			"string": "This port of the Industries of Enceladus mod aims to bring full compatability with the content of IoE with that of other equipment mods. \\n\\nCompatability with saves using the original IoE isn't supported (yet)",
			"version_hash": 3666305633
		},
		"IOE_MOD_BRIEF": {
			"string": "Overhaul content mod with over a dozen ships, 50 equipment items, and much more...",
			"version_hash": 1435637786
		},
		"SLOT_CARGO_AUX": {
			"string": "Cargo Bay Accessories",
			"version_hash": 898983681
		},
		"SYSTEM_FUEL_1000000": {
			"string": "2x Freighter propellant tank array",
			"version_hash": 2936829597
		},
		"SYSTEM_FUEL_1000000_DESC": {
			"string": "A doubled-up array of freighter-class propellant tanks that can hold up to 1,000,000 kg of propellant for thermal rockets. Honeycombed cells prevent mass shifts during maneuvers.",
			"version_hash": 130411686
		},
		"SYSTEM_FUEL_1000000_SPECS": {
			"string": "Capacity: 1,000,000 kg \\nPropellant type: Thermal Rocket",
			"version_hash": 3150131236
		},
		"SYSTEM_FUEL_2000000": {
			"string": "Frigate propellant tank array",
			"version_hash": 428941173
		},
		"SYSTEM_FUEL_2000000_DESC": {
			"string": "A sprawling, decommissioned military-class fuel tank array that can hold up to 2,000,000 kg of propellant for thermal rockets. Honeycombed cells prevent mass shifts during maneuvers.",
			"version_hash": 1601193690
		},
		"SYSTEM_FUEL_2000000_SPECS": {
			"string": "Capacity: 2,000,000 kg \\nPropellant type: Thermal Rocket",
			"version_hash": 901361093
		},
		"SYSTEM_THRUSTER_PIN150": {
			"string": "RMS Pin-C50 thruster",
			"version_hash": 503674612
		},
		"SYSTEM_THRUSTER_PIN150_DESC": {
			"string": "The Rasamama Material Solutions Pin-C50 is a unique solid-state thruster system that utilises pulsed induction to accelerate and vector hydrogen plasma without the need for any mechanical components, massively minimising the damage-related issues associated with conventional thrusters. However, they do suffer extra stress while under acceleration, and will fail at considerably lower accelerations than conventional thrusters. \\n\\nWhile incredibly hard-wearing, the installation of heavy plasma conduits and supporting power infrastructure, as well as the thrusters' direct embedment into the vessel hull, requires specialist assistance that may be difficult to afford.",
			"version_hash": 1349732115
		},
		"SYSTEM_THRUSTER_PIN150_SPECS": {
			"string": "Thrust: 150 kN \\nExhaust velocity: 90 km/s \\nPropellant consumption: 1.6 kg/s \\nPower consumption: 90 MW \\nThermal consumption: 6.8 GW \\nOperation mode: Virtual variable thrust \\nVectored thrust angle: 36 deg \\nPropellant: Hydrogen plasma \\nMass: 185 kg (per thruster) \\nManufacturer: Rasamama Material Solutions",
			"version_hash": 1856467542
		},
		"SYSTEM_THRUSTER_BLAST": {
			"string": "ERS-BlasTR 7200 thruster",
			"version_hash": 657341998
		},
		"SYSTEM_THRUSTER_BLAST_DESC": {
			"string": "Electro Ride Systems' BlasTR is a complete deviation from their previous NAGHET, utilising a helical magnetoplasmadynamic accelerator to achieve spectacular thrust at equally improbable exhaust velocities. Primarily marketed towards racing ships, it has also seen interest from operators of heavy vessels, whose high thrust requirements have long been overserved by thrusters with poor propellant economies.",
			"version_hash": 1965070975
		},
		"SYSTEM_THRUSTER_BLAST_SPECS": {
			"string": "Thrust: 450 kN \\nExhaust velocity: 22 km/s \\nPropellant consumption: 20.5 kg/s \\nPower consumption: 72 MW \\nThermal consumption: 5.0 GW \\nOperation mode: Variable thrust \\nPropellant: Oxygen-Hydrogen plasma \\nMass: 145 kg (per thruster) \\nManufacturer: Electro Ride Systems",
			"version_hash": 1023832149
		},
		"SYSTEM_THRUSTER_PNTRM": {
			"string": "ND-PNTRm thruster",
			"version_hash": 1339790742
		},
		"SYSTEM_THRUSTER_PNTRM_DESC": {
			"string": "The remarkable success of the PNTR indicated to Nakamura Dynamics that the age-old problem of delicate gimbal mounts could be entirely sidestepped with solid-state thrust vectoring technology, and the company quickly set to work on effectively downscaling the system for use as RCS thrusters.  \\n\\nDespite its poor exhaust velocity as a pure NTR, the Pulsed Nuclear Thermal Rocket (Micro) makes up for it with the largest effective thrust vectoring range on the market today. Its low operational cost and fast warmup makes it ideal for heavier ships with limited RCS thruster layouts.",
			"version_hash": 2424136332
		},
		"SYSTEM_THRUSTER_PNTRM_SPECS": {
			"string": "Thrust: 450 kN \\nExhaust velocity: 5 km/s \\nPropellant consumption: 90.0 kg/s \\nPower consumption: 40 MW \\nThermal consumption: 1.8 GW \\nOperation mode: Pulsed thrust \\nVectored thrust angle: 60 deg \\nPropellant: Oxygen-Hydrogen plasma \\nMass: 25 kg (per thruster) \\nManufacturer: Nakamura Dynamics",
			"version_hash": 3803267296
		},
		"SYSTEM_SALVAGE_ARM_HEAVY": {
			"string": "Rusatom-Antonoff ORD",
			"version_hash": 3844473405
		},
		"SYSTEM_SALVAGE_ARM_HEAVY_DESC": {
			"string": "Through the course of their collaboration on the KTA24, Rusatom-Antonoff quickly recognised the shortcomings of the Triskellion-Armstrong AR-1500. A slow and delicate device, its usage as an ore recovery tool quickly wears out its precision servos and carefully-constructed docking adapter. The ORD is their response to such shortcomings. \\n\\nWhile especially heavy and power-hungry on account of its bulky support structure, its hard-wearing motors and bearings offer a viable and durable alternative to its counterpart. ",
			"version_hash": 4017619073
		},
		"SYSTEM_SALVAGE_ARM_HEAVY_SPECS": {
			"string": "Arm strength: 3,200 kN \\nReach: 40 m \\nPower draw (peak): 220 MW \\nMounting Location: High-stress only \\nMass: 14,000 kg \\nManufacturer: Rusatom-Antonoff",
			"version_hash": 14878473
		},
		"SYSTEM_SALVAGE_ARM_LIGHT": {
			"string": "Runasimi KRB-500",
			"version_hash": 3632982126
		},
		"SYSTEM_SALVAGE_ARM_LIGHT_DESC": {
			"string": "The Runasimi KRB-500 Sample Manipulator was originally developed for the vessels of lesser-funded research organisations, but has recently found a new niche in the mining sector as a convenient alternative to nanodrone systems. \\n\\nThe manipulator's actuators use fluid couplings with brake discs to simulate the precision of stepper or servo motors, a novel implementation that minimises maintenance expenses and overall mass. In addition, its claw can be magnetised to clamp to the outer hull of small ferromagnetic objects such as drone hulls, but its holding strength may be inadequate for larger vessels. \\n\\nNote: analysis and experiment packages are available as a separate purchase.",
			"version_hash": 2076300310
		},
		"SYSTEM_SALVAGE_ARM_LIGHT_SPECS": {
			"string": "Arm strength: 500 kN \\nReach: 35 m \\nPower draw (peak): 60 MW \\nMass: 2,050 kg \\nManufacturer: Runasimi Inc.",
			"version_hash": 2860574801
		},
		"SYSTEM_SALVAGE_ARM_LONG": {
			"string": "TR-60 Extended Manipulator",
			"version_hash": 3370268219
		},
		"SYSTEM_SALVAGE_ARM_LONG_DESC": {
			"string": "Triskellion-Armstrong's solution for a collection-oriented manipulation arm. Intelligent structural design with ingenious mechanisms allow for high torque from a relatively nimble frame, however the use of complicated proprietary parts make for a frequently expensive and arduous maintenance cycle.",
			"version_hash": 2981052471
		},
		"SYSTEM_SALVAGE_ARM_LONG_SPECS": {
			"string": "Arm strength: 700 kN \\nReach: 60 m \\nPower draw (peak): 170 MW \\nMass: 7,750 kg \\nManufacturer: Triskelion-Armstrong",
			"version_hash": 4230989901
		},
		"SYSTEM_MAIN_ENGINE_NANI": {
			"string": "SSE NANI Torch Refit",
			"version_hash": 102908080
		},
		"SYSTEM_MAIN_ENGINE_NANI_DESC": {
			"string": "This comically impractical and completely disgusting main torch is the ultimate logical conclusion of many a night spent drinking and ruminating on life's purpose. Coming to the determination that there isn't one, the team at Sin Space Engineering put their heads together and produced this thing. \\n\\nDisclaimer: Omaewamou-Shindeiru thinks this is really funny and fully endorses the NANI's use as a propulsion solution. May void vessel warranty. Usage as main torch in some vessels may damage your reactor. Have fun!",
			"version_hash": 1452558551
		},
		"SYSTEM_MAIN_ENGINE_NANI_SPECS": {
			"string": "Thrust: 3,450 kN \\nExhaust velocity: 132 km/s \\nPropellant consumption: 0.5 kg/s \\nPower consumption: 200 MW \\nThermal consumption: 2 GW \\nPropellant: Supercritical liquid uranium salt \\nBurn time: 1 minute (est) \\nMass: 10,000 kg \\nManufacturer: Sin Space Engineering / Omaewamou-Shindeiru",
			"version_hash": 2648206337
		},
		"SYSTEM_MAIN_ENGINE_GEMINI": {
			"string": "MA-NTR600-II dual engine",
			"version_hash": 2716215589
		},
		"SYSTEM_MAIN_ENGINE_GEMINI_DESC": {
			"string": "The NTR600-II, otherwise known as the \"Gemini\", is a dual-mounted magnetoplasmadynamic torch unit capable of delivering decent thrust with excellent efficiency and reliability. The dual exhaust layout in combination of a basic thrust vectoring system also allows for additional vectoring potential, furthering the potential efficiency of the torch. \\n\\nDisclaimer: maintenance of this unit is to be performed only by Mitsudaya-Starbus engineers or licensed sub-contractors. Insurance plans are not yet available in the outer solar system.",
			"version_hash": 3220815468
		},
		"SYSTEM_MAIN_ENGINE_GEMINI_SPECS": {
			"string": "Thrust: 1,200 kN \\nExhaust velocity: 28 km/s \\nPropellant consumption: 52 kg/s \\nPower consumption: 250 MW \\nThermal consumption: 16.8 GW \\nVectored thrust angle: 60 deg \\nVectoring speed: 20 deg/s \\nOperation mode: Variable thrust \\nPropellant: Hydrogen plasma \\nMass: 4,350 kg \\nManufacturer: Mitsudaya-Starbus",
			"version_hash": 3065622450
		},
		"SYSTEM_MAIN_ENGINE_SOYUZ": {
			"string": "RA-TNTRL-R44 quad engine",
			"version_hash": 3205954369
		},
		"SYSTEM_MAIN_ENGINE_SOYUZ_DESC": {
			"string": "It's by no stretch of the imagination that this \"torch\" exists. Rusatom-Antonoff aimed to compete with other multiple-torch assemblies by introducing their own, but development was slow, and by the end of the 22nd century, many prototypes had been tried and failed with no viable solutions. \\n\\nMyths of its invention process vary, but generally suggest that the lead designer on the project was visited in a dream by the ghost of legendary Soviet rocket engineer Valentin Glushko. He spoke one word, 'Soyuz', and then departed, leaving the K44 RCS thruster at the designer's feet. \\n\\nProduction of these combined units continues to this day, and is part of the reason why the K44 thruster is still so abundant.",
			"version_hash": 1366834651
		},
		"SYSTEM_MAIN_ENGINE_SOYUZ_SPECS": {
			"string": "Thrust: 1,600 kN \\nExhaust velocity: 15 km/s \\nPropellant consumption: 106.4 kg/s \\nPower consumption: 60 MW \\nThermal consumption: 12.0 GW \\nOperation mode: Pulsed thrust \\nPropellant: Oxygen-Hydrogen plasma \\nMass: 650 kg \\nManufacturer: Rusatom-Antonoff",
			"version_hash": 98769096
		},
		"SYSTEM_MAIN_ENGINE_THUNDER": {
			"string": "RA-K69V quad engine",
			"version_hash": 3527062166
		},
		"SYSTEM_MAIN_ENGINE_THUNDER_DESC": {
			"string": "This torch is a custom-engineered piece of equipment that takes the frame of an R44 and replaces its engines with K69V thrusters, complete with the gimbal mountings the line is so famous for among ringside racers. Installation comes with optional and entirely legal \"Thunderbarge-class\" transponder modification. Personal grappling hook available on special request.",
			"version_hash": 2146529517
		},
		"SYSTEM_MAIN_ENGINE_THUNDER_SPECS": {
			"string": "Thrust: 1,600 kN \\nExhaust velocity: 12 km/s \\nPropellant consumption: 133.2 kg/s \\nPower consumption: 100 MW \\nThermal consumption: 14.4 GW \\nGimbal angle: 25 deg \\nGimbal speed: 360 deg/s \\nOperation mode: Pulsed thrust, gimballed \\nPropellant: Oxygen-Hydrogen plasma \\nMass: 950 kg \\nManufacturer: Custom-built / Rusatom-Antonoff",
			"version_hash": 3513946357
		},
		"SYSTEM_MAIN_ENGINE_PIN1200": {
			"string": "RMS Pin-M200 engine",
			"version_hash": 1077983648
		},
		"SYSTEM_MAIN_ENGINE_PIN1200_DESC": {
			"string": "The Rasamama Material Solutions Pin-M200 implements the same pulsed induction technology that powers its Pin-150 series of solid-state RCS thrusters on a larger scale. The upscaling of the tech does make for a more fragile thruster, however it is still well within the bounds of competitor's reliability data. \\n\\nThe sheer thermal power of the upscaled technology posed a nominal burn requirement of well over 60 GW direct from the reactor. Considering that it outpaces even racing reactors, it was decided to include a micro fusion reactor for the power supply. Unlike equivalent fusion torches, this reactor is used solely for the purpose of providing heat, rather than being essential to the generation of thrust. A limited tank of fusion fuel limits burn time to roughly an hour and a half.",
			"version_hash": 3023964548
		},
		"SYSTEM_MAIN_ENGINE_PIN1200_SPECS": {
			"string": "Thrust: 1,200 kN \\nExhaust velocity: 105 km/s \\nPropellant consumption: 11.4 kg/s \\nPower consumption: 550 MW \\nVectoring angle: 40 deg \\nOperation mode: Variable thrust \\nPropellant: Hydrogen plasma / uranium salt \\nBurn time: 90 minutes (est) \\nMass: 11,350 kg \\nManufacturer: Rasamama Material Solutions",
			"version_hash": 3613207065
		},
		"SYSTEM_MAIN_ENGINE_CRACK": {
			"string": "NDDFD engine",
			"version_hash": 4036807547
		},
		"SYSTEM_MAIN_ENGINE_CRACK_DESC": {
			"string": "The Directed Fusion Detonation engine by Nakamura Dynamics is one of the most powerful - and earliest! - fusion propulsion solutions still on the market. Popularised by a now-infamous 2214 advertisement backed by the Vengaboys' \"Boom, Boom, Boom, Boom\", the NDDFD utilises powerful electromagnets to crush remass-heated ferromagnetic shells containing pressurised deuterium and tritium, then direct the resultant detonation out of its cage-like nozzle assembly. \\n\\nUnlike its competitor, the NDDFD requires a enormous and continuous supply of power to maintain propulsion, and its relatively large pellets and specialised feed hardware dramatically limits its fuel capacity in small vessels.",
			"version_hash": 1952062653
		},
		"SYSTEM_MAIN_ENGINE_CRACK_SPECS": {
			"string": "Thrust: 1,800 kN \\nExhaust velocity: 1,850 km/s \\nPropellant consumption: 1 kg/s \\nPower consumption: 445 MW \\nOperation mode: Pulsed thrust \\n Propellant: Hydrogen plasma \\nFusion fuel: D-T \\nBurn time: 30 minutes (est) \\nMass: 4,650 kg \\nManufacturer: Nakamura Dynamics",
			"version_hash": 1438267236
		},
		"SYSTEM_MAIN_ENGINE_ZURBIN": {
			"string": "ND ZURBIN engine",
			"version_hash": 3993811975
		},
		"SYSTEM_MAIN_ENGINE_ZURBIN_DESC": {
			"string": "The Zurbin engine is the high-performance main engine of the Tsukuyuomi class of frigates. Now decomissioned, these engines see use still aboard the frigates, albeit long gone from the days of combat involvement. Nakamura Dynamics did make a push to reuse any from scrapped frigates, putting them to use in their Phage class of autonomous stations.",
			"version_hash": 601565468
		},
		"SYSTEM_MAIN_ENGINE_ZURBIN_SPECS": {
			"string": "Thrust: 6,900 kN \\nExhaust velocity: 66 km/s \\nPropellant consumption: 104.5 kg/s \\nPower consumption: 50 MW \\nOperation mode: Variable thrust \\nPropellant: Oxygen-Hydrogen plasma \\nMass: 10,000 kg \\nManufacturer: Nakamura Dynamics",
			"version_hash": 1881930709
		},
		"SYSTEM_MAIN_ENGINE_PMS": {
			"string": "ND PMS engine",
			"version_hash": 3240131645
		},
		"SYSTEM_MAIN_ENGINE_PMS_DESC": {
			"string": "The PMS is an early predecessor to the NTTR thruster. Nakamura Dynamics's first large NTR type thruster holds an abysmal propellant economy and sub-par thrust for a raw NTR, it still holds out for it's sheer reliability. Able to operate under stresses far-exceeding any other thruster on the market, and being incredibly sturdy for it's power, the PMS still keeps up with demand for a thruster able to keep running, even in situations that would be considered dire using alternatives.",
			"version_hash": 2154944331
		},
		"SYSTEM_MAIN_ENGINE_PMS_SPECS": {
			"string": "Thrust: 3,000 kN \\nExhaust velocity: 3 km/s \\nPropellant consumption: 1,000 kg/s \\nPower consumption: 20 MW \\nThermal consumption: 4.5 GW \\nOperation mode: Variable thrust \\nPropellant: Oxygen-Hydrogen plasma \\nMass: 250 kg \\nManufacturer: Nakamura Dynamics",
			"version_hash": 285575969
		},
		"IOER_TRANSIT_TIP_1": {
			"string": "Preprocessor units draw water out of a chunk before it meets the mineral processing unit to speed up the time it takes for the chunk to be processed.",
			"version_hash": 1298930922
		},
		"IOER_TRANSIT_TIP_2": {
			"string": "Preprocessors with mineral efficiency bonuses increase the amount of metal you can extract from a chunk.",
			"version_hash": 2657296036
		},
		"IOER_TRANSIT_TIP_3": {
			"string": "Want to use the variable processed ore storage of the Cothon-217 with another ship? Use hold conversion kits like the NDSBH.",
			"version_hash": 697902233
		},
		"IOER_TRANSIT_TIP_4": {
			"string": "Need extra processed ore storage? Install a hold expansion module or a bay auxiliary storage module.",
			"version_hash": 1984517216
		},
		"IOER_TRANSIT_TIP_5": {
			"string": "Habitat kits can improve the crew capacity of your ship, but watch for any changes in morale created by the new conditions.",
			"version_hash": 2261321500
		},
		"IOE_TUNE_PARAMETER_PREPROC_MELT_POWER_DRAW": {
			"string": "Water Reduction Power Draw (per chunk)",
			"version_hash": 1562137441
		},
		"IOE_TUNE_PREPROC_RECLAIM": {
			"string": "Ice Thawing Speed",
			"version_hash": 3472595481
		},
		"IOE_TUNE_PREPROC_RECLAIM_DESC": {
			"string": "Increasing the processing speed of a preprocessor improves water melt speed by rerouting extra power to the unit. This decreases efficiency of the unit cuased by the overheating, however the additional heat produced by the unit combined with additional power provided to melting facilities (if applicable) cause chunks to lose more water.\\n\\nSlowing down the process enhances water capture efficiency and lowers power usage.",
			"version_hash": 367626968
		},
		"IOE_TUNE_PARAMETER_PREPROC_MELT_REMASS_EFFICIENCY": {
			"string": "Ice Remass Reclamation Efficiency",
			"version_hash": 3782386725
		},
		"IOE_TUNE_PARAMETER_PREPROC_CHUNK_WATER_MASS_CEILING": {
			"string": "Minimum Chunk Water Content",
			"version_hash": 840275576
		},
		"IOE_TUNE_FAB_SPEED": {
			"string": "Fabrication Print Speed",
			"version_hash": 4127227909
		},
		"IOE_TUNE_FAB_SPEED_DESC": {
			"string": "Modifies the rate at which the fabrication unit converts processed ore into consumables. Inefficiencies within the production line will scale with production rate, with an increased speed requiring more power and material in the process.",
			"version_hash": 3230248524
		},
		"IOE_TUNE_PARAMETER_PRINT_POWER_DRAW": {
			"string": "Printing Power Draw",
			"version_hash": 3168425227
		},
		"IOE_TUNE_PARAMETER_PRINT_MATERIAL_EFFICIENCY": {
			"string": "Additional material cost from inefficiencies",
			"version_hash": 2047110542
		},
		"SYSTEM_MWTIGHTBEAM": {
			"string": "RA DMW Cannon",
			"version_hash": 2618579005
		},
		"SYSTEM_MWTIGHTBEAM_DESC": {
			"string": "Rusatom-Antonoff's Directed Microwave Cannon utilises a long, tubular waveguide to concentrate microwaves into a tight beam of irradiance. Its modular and unspecialised components are cheap and quick to repair, but are offset by high installation costs and middling power efficiency.",
			"version_hash": 2758148380
		},
		"SYSTEM_MWTIGHTBEAM_SPECS": {
			"string": "Effective range: 800 m \\nPower consumption: 120 MW \\nOutput power: 90 MW \\nWavelength: 1 cm \\nMass: 400 kg \\nManufacturer: Rusatom-Antonoff",
			"version_hash": 4287019540
		},
		"SYSTEM_MWTIGHTBEAM_PDT": {
			"string": "RA DMW Cannon Turret",
			"version_hash": 372221731
		},
		"SYSTEM_MWTIGHTBEAM_PDT_DESC": {
			"string": "This version of the Rusatom-Antonoff DMW Cannon is mounted onto a Nakamura Dynamics NDPT turret body. It enjoys similar handling characteristics and the adjustable configuration parameters of their 42xx line of point-defense railgun turrets, though its gimbal driver had to be downgeared to properly manage the unit's heavy AC cabling. \\n\\nThe DMW-CT can automatically acquire and track targets, but, unlike its railgun counterpart, does not require manual input to fire.",
			"version_hash": 1054989203
		},
		"SYSTEM_MWTIGHTBEAM_PDT_SPECS": {
			"string": "Effective range: 2000 m \\n Targeting AI: Class-1 \\nPower consumption: 120 MW \\nOutput power: 90 MW \\nWavelength: 1 cm \\nMass: 3,000 kg \\nManufacturer: Rusatom",
			"version_hash": 2660111544
		},
		"SYSTEM_PDTL": {
			"string": "NDCL-80 Point Defence Laser Turret",
			"version_hash": 4025363180
		},
		"SYSTEM_PDTL_MANUAL": {
			"string": "Automatically picks targets.\\nFires automatically.\\nCoordinates across multiple systems.\\nTargeting computer is imperfect.\\nDisable the hardpoint to prevent accidental friendly fire.\\nDeals thermal damage.",
			"version_hash": 2781923848
		},
		"SYSTEM_PDTL_DESC": {
			"string": "A small laser attached to a turret base allows for a wide coverage from the hardpoint's point of view. The lower power makes for a bit of extra work on the laser to break rocks, however it prevents as much damage dealt to targets. It fires automatically, so users are warned to have proper control over their governing IFF systems to prevent unwanted conflict. \\n\\nTHE HARDWARE IS PROVIDED \\\"AS IS\\\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED. THE USER ASSUMES ALL LIABILITY WITH THE USE OF THIS EQUIPMENT",
			"version_hash": 1832670728
		},
		"SYSTEM_PDTL_SPECS": {
			"string": "Effective range: 1,000 m \\nTargeting AI: Class-1 \\nPower consumption (peak): 80 MW \\nMass: 1,500 kg \\nManufacturer: Nakamura Dynamics, Coherent Light",
			"version_hash": 1972137821
		},
		"POI_WRECKAGE_UNKNOWN": {
			"string": "Mysterious Wreckage",
			"version_hash": 3678810514
		}
	},
	"ru_RU": {
		"SYSTEM_CARGO_AUX_FAB": {
			"string": "Фабрикатор SSE Voyager",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_FAB_DESC": {
			"string": "Изготовленное на заказ и совершенно нелицензированное чудовище от Sin Space Engineering, ставшее популярным среди шахтёров кольца в 2260-х годах. Модуль-фабрикатор Voyager RSLS MPU был демонтирован и размещён выше в грузовом отсеке вместе с небольшим хранилищем минералов для замены специализированных загрузочных бункеров. \\n\\nВ связи с заменой шины питания на распределитель более низкого качества ожидается умеренное снижение энергоэффективности по сравнению со стандартным блоком. \\n\\nОтказ от ответственности: Nakamura Dynamics не предоставляет гарантию на этот блок и не считает его частью своего ассортимента продукции, явным или подразумеваемым. Использование модифицированного оборудования может привести к повреждениям и непредвиденным опасностям.",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_FAB_SPECS": {
			"string": "Потребляемая мощность при печати: 120 МВт \\nВозможности печати: дроны, боеприпасы \\nГрузоподъёмность: 2000 кг / минерал (всего 12 000 кг) \\nЗапас топлива: 6000 кг \\nКоэффициент скорости обработки УПМ: 155% от скорости УПМ \\nДополнительные затраты мощности УПМ на единицу продукции: ~55% \\nМасса: 5000 кг \\nПроизводитель: Sin Space Engineering / Nakamura-Obonto",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_FAB_MANUAL": {
			"string": "Для корректной работы требуется установка переработки минералов (УПМ). \\nПассивно увеличивает объём перерабатываемого груза на борту. \\nПереработанная руда хранится в отдельных контейнерах, вместимость которых ограничена для каждого типа минерала. \\nПроизводит кинетические боеприпасы из смеси железа и ванадия в соотношении 9:1. \\nПроизводит компоненты нанодрона из смеси железа и платины в соотношении 4:1. \\nЗанимает некоторое место в грузовом отсеке.",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_BIGFAB": {
			"string": "Фабрикатор RMS-PAL",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_BIGFAB_DESC": {
			"string": "Портативная сборочная линия Rasamama Material Solutions — настоящее чудо автоматизации, включающее два ИИ класса 1 (ARTEMIS и APOLLO), которые контролируют работу друг друга в условиях противостояния. Его выдающаяся производительность полностью обусловлена ​​постоянной оптимизацией ситуации, а его большие приёмные бункеры могут быть подключены к внутренним хранилищам судна в качестве вспомогательных мест хранения расходных материалов. \\n\\nВнимание: характеристики ИИ соответствуют категории 1 согласно Лос-Анджелесской конвенции 2184 года. Ни ARTEMIS, ни APOLLO не предназначены для разумного использования или коммуникации. Немедленно сообщайте в ATLAS о любых отклонениях в поведении.",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_BIGFAB_SPECS": {
			"string": "Потребляемая мощность при печати: 210 МВт \\nВозможности печати: дроны, боеприпасы \\nВместимость боеприпасов: 5000 кг \\nВместимость дронов: 5000 кг \\nМасса: 10 500 кг \\nПроизводитель: Rasamama Material Solutions",
			"version_hash": 0
		},
		"SLOT_CARGO_MPU": {
			"string": "УПМ Грузового отсека",
			"version_hash": 0
		},
		"SYSTEM_CARGO_MPU_FURN": {
			"string": "УПМ Rusatom-Antonoff Mk2",
			"version_hash": 0
		},
		"SYSTEM_CARGO_MPU_FURN_DESC": {
			"string": "Эта модификация Mark-2 установки переработки руды «Rusatom-Antonoff», которую шахтеры ласково называют «Галпер», сочетает в себе лучшие качества своей предшественницы с приемной манжетой и дополнительными нагревательными элементами, повышая общую эффективность и производительность рекультивации за счет уменьшения рабочей зоны.",
			"version_hash": 0
		},
		"SYSTEM_CARGO_MPU_FURN_SPECS": {
			"string": "Скорость переработки: 25 кг/с \\nЭнергопотребление: 25 МВт/осколок \\nЭффективность переработки минералов: 60% \\nЭффективность переработки топлива: 40% \\nМасса: 3000 кг \\nПроизводитель: «Rusatom-Antonoff»",
			"version_hash": 0
		},
		"SYSTEM_CARGO_MPU_BULK": {
			"string": "УПМ «Bulker» от Titan Heavy Industries",
			"version_hash": 0
		},
		"SYSTEM_CARGO_MPU_BULK_DESC": {
			"string": "УПМ «Bulker» от Titan Heavy Industries был представлен на рынке в середине 2200-х годов, но начал распространяться среди шахтёров Энцелада только после заключения торговых соглашений в 2260-х годах. Его простая конструкция — классический пример инженерного подхода THI «меньше значит больше». \\n\\nТяжёлый и неудобный для загрузки по сравнению с другими МПУ, «Булкер» уникален благодаря своей встроенной ёмкости для хранения. Внутренние компоненты дрона THI-CC размещены под зоной переработки. Несмотря на уменьшение размера бункеров, они по-прежнему способны значительно увеличить вместимость любого судна, на котором установлены.",
			"version_hash": 0
		},
		"SYSTEM_CARGO_MPU_BULK_SPECS": {
			"string": "Грузоподъемность: 10 000 кг/минерал (всего 60 000 кг) \\nСкорость переработки: 40 кг/с \\nЭнергопотребление: 100 МВт/осколок \\nЭффективность переработки минералов: 70% \\nЭффективность переработки топлива: 20% \\nМасса: 8 000 кг \\nПроизводитель: Titan Heavy Industries",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_PREPROC_0x30": {
			"string": "Rasamama RP-25",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_PREPROC_0x30_DESC": {
			"string": "Rasamama Material Solutions RP-25 — это малогабаритная установка предварительной обработки руды (препроцессор), предназначенная исключительно для растопления льда с кусков минералов в грузовом отсеке судна и не более того. Установка использует линию отбора пара из турбины реактора для получения тепловой энергии и требует очень мало электроэнергии для своей работы. \\n\\nРабочее тело получается за счёт пропускания отходящих газов через конденсаторно-радиаторную панель, установленную на корпусе судна. Rasamama MS рекомендует проводить ежемесячные испытания потока с последующей продувкой горячим газом для предотвращения загрязнения.",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_PREPROC_0x30_SPECS": {
			"string": "Скорость таяния льда: 20 кг/с \\nЭффективность переработки препроцессора: 45% \\nЭнергопотребление: 1250 кВт/осколок \\nКоэффициент эффективности обработки минералов УПМ: x100% (без изменений) \\nИзменение скорости обработки УПМ: -10 кг/с \\nИзменение мощности УПМ: минимальное снижение \\nМасса: 750 кг \\nПроизводитель: Rasamama Material Solutions",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_PREPROC_20x10": {
			"string": "Nakamura Big MT",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_PREPROC_20x10_DESC": {
			"string": "Установка предварительной обработки руды (препроцессор) Big MT компании Nakamura Dynamics использует основные принципы обработки руды в своих интересах. Свободный пар в грузовом отсеке перегревается мощным тороидальным радиатором установки, что обеспечивает быстрое сублимирование льда и предварительный нагрев образующихся металлических частиц для более эффективной обработки. \\n\\nХотя часть технологического пара может быть использована в качестве топлива, компактный конденсатор установки часто перегружен из-за большого объёма и высоких температур. \\n\\nВнимание: при разработке этой установки ни один лоботомит не пострадал.",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_PREPROC_20x10_SPECS": {
			"string": "Скорость таяния льда: 25 кг/с \\nЭффективность переработки препроцессора: 10% \\nЭнергопотребление: 125 кВт/осколок \\nКоэффициент эффективности обработки минералов УПМ: x115% \\nИзменение скорости обработки УПМ: 90% от номинальной \\nИзменение мощности УПМ: снижение на 10% \\nМасса: 2000 кг \\nПроизводитель: Nakamura Dynamics",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_PREPROC_40x20": {
			"string": "Rusatom-Antonoff MPP-N1",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_PREPROC_40x20_DESC": {
			"string": "MPP-N1 — один из лучших препроцессоров (установка предварительной обработки руды) на рынке, обеспечивающий превосходный прирост эффективности и выхода топлива благодаря магнитогидродинамической системе. \\n\\nУстановка использует выхлопные газы реакторной установки в качестве источника тепла, подавая их в отсек через колбу в центре. Электромагнитные катушки, окружающие колбу, регулируют температуру посредством индукционного нагрева. \\n\\nТехнологический пар и микроэлементы улавливаются конденсатором с перегородками. Для обеспечения максимальной эффективности рекомендуется замена конденсаторного блока через 320 летных часов.",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_PREPROC_40x20_SPECS": {
			"string": "Скорость таяния льда: 40 кг/с \\nЭффективность переработки рабочей массы препроцессором: 20% \\nЭнергопотребление: 375 кВт/осколок \\nКоэффициент эффективности обработки минералов УПМ: x130% \\nИзменение скорости обработки УПМ: 80% от номинальной скорости \\nИзменение мощности УПМ: снижение на 20% \\nМасса: 6500 кг \\nПроизводитель: «Rusatom-Antonoff»",
			"version_hash": 0
		},
		"SYSTEM_CARGO_PREPROC_P15": {
			"string": "Rusatom Chunk Cutter",
			"version_hash": 0
		},
		"SYSTEM_CARGO_PREPROC_P15_DESC": {
			"string": "RCC был разработан на заре развития технологий модификации отсеков и, в отличие от большинства компаний того времени, фокусировался на способности пропускать руду через препроцессор, а не на эффективности её выхода. Используя постоянное, но тонкое покрытие из магния, подсвечиваемое лазерами зажигания препроцессора, вода искусственно вытапливается, что сокращает время прохождения куска через препроцессор. Дополнительное тепло, выделяемое при зажигании, приводит к небольшому дальнейшему плавлению, однако из-за сильного содержания примесей, образующихся в процессе, он непригоден для регенерации топлива. \\n\\nЗаправочные блоки из магниевого порошка доступны бесплатно на Энцеладе Прайм.",
			"version_hash": 0
		},
		"SYSTEM_CARGO_PREPROC_P15_SPECS": {
			"string": "Коэффициент скорости переработки УПМ: 100% от скорости УПМ \\nМодификатор скорости переработки вторичного УПМ: 15 кг/с \\nДополнительные затраты мощности УПМ на один блок: минимальные \\nЭнергопотребление: 150 кВт/осколок \\nСкорость таяния льда: 5 кг/с \\nМасса: 1220 кг \\nПроизводитель: «Rusatom»",
			"version_hash": 0
		},
		"SYSTEM_CARGO_PREPROC_M35": {
			"string": "MAD Heating Coils",
			"version_hash": 0
		},
		"SYSTEM_CARGO_PREPROC_M35_DESC": {
			"string": "Этот специализированный блок переработки использует структурированное плавление кусков руды, поступающих в отсек, для создания более хрупкой структуры льда. Этот блок также оснащен вторичным блоком повышения эффективности, который крепится к самому блоку УПМ для повышения скорости обработки и скорости извлечения минералов. \\n\\nЭто устройство подвергается серьёзной критике со стороны компаний, использующих его в течение длительного времени, поскольку фирменные компоненты быстро выходят из строя уже через несколько месяцев использования.",
			"version_hash": 0
		},
		"SYSTEM_CARGO_PREPROC_M35_SPECS": {
			"string": "Коэффициент скорости переработки УПМ: 135% от скорости УПМ \\nМодификатор скорости переработки вторичного УПМ: 10 кг/с \\nДополнительные затраты мощности УПМ на один кусок: ~38% \\nСкорость таяния льда: 30 кг/с \\nЭффективность переработки топлива препроцессора: 10% \\nЭнергопотребление: 550 кВт/осколок \\nМножитель эффективности переработки минералов УПМ: x110% \\nМасса: 4780 кг \\nПроизводитель: Machines Astro-Dynamiques",
			"version_hash": 0
		},
		"SYSTEM_CARGO_PREPROC_M85": {
			"string": "MS Frakker",
			"version_hash": 0
		},
		"SYSTEM_CARGO_PREPROC_M85_DESC": {
			"string": "Frakker от Mitsudaya-Starbus использует комбинацию высокопроизводительных катушек и чипов распознавания образов для оптимизации таяния и разрушения льда. Использование чипов ИИ с функцией распознавания образов связано с методом геологической разведки, распространённым в начале XXI века, когда был высок интерес к алгоритмам LLM для наблюдения и определения оптимального способа дробления руды с сохранением потерь минералов, превышающих потери базового блока. В результате использование этого блока сопряжено с большими энергозатратами, поскольку отслеживание каждого куска руды создаёт дополнительное потребление энергии за всё время его нахождения в зоне сканирования. \\n\\nВыделяемое этим блоком тепло также вызывает небольшое плавление кусков руды, однако система его переработки в рабочее тело так и не была создана.",
			"version_hash": 0
		},
		"SYSTEM_CARGO_PREPROC_M85_SPECS": {
			"string": "Коэффициент скорости переработки УПМ: 185% от скорость УПМ \\nМодификатор скорости переработки вторичного УПМ: 0 кг/с \\nДополнительные затраты мощности УПМ на один кусок: ~85% \\nУправляющий ИИ: Класс 1 \\nЭнергопотребление: 2500 кВт/осколок \\nСкорость таяния льда: 12 кг/с \\nМасса: 12 550 кг \\nПроизводитель: Mitsudaya-Starbus",
			"version_hash": 0
		},
		"SYSTEM_CARGO_AUX_PREPROC_MANUAL": {
			"string": "Уменьшает массу льда на кусках на большой площади. \\nПополняет запас топлива. \\nМультипликативно увеличивает эффективность УПМ. \\nМультипликативно снижает скорость обработки УПМ. \\nОбрабатывает несколько кусков руды одновременно. \\nТребования к мощности и скорости обработки указаны для одного куска. \\nИзменяет скорость переработки УПМ и энергопотребление за один осколок. \\nНе добывает минералы и не уничтожает осколки.",
			"version_hash": 0
