		"SYSTEM_HULLVAT_NANO_EXTEND_2": {
			"string": "Antonoff Dual Nano Storage Expansion",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_NANO_EXTEND_2_DESC": {
			"string": "Аналогично конструкции комплектов для увеличения боеприпаса, компания Antonoff предложила двойную комплектацию для своих NSE. Аналогичные ограничения сохраняются.",
