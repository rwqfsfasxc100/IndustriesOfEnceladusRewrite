			"version_hash": 0
		},
		"SYSTEM_HULLVAT_NANO_EXTEND_3": {
			"string": "Obonto Liquid Nanobot Hold",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_NANO_EXTEND_3_DESC": {
			"string": "Вариант комплекта Obonto Projectile Extendo+ для хранения нанодронов. Этот комплект заменяет довольно большую часть топливного бака для хранения дополнительных компонентов нанодрона. Этот вариант на удивление популярен среди строительных бригад, несмотря на проблемы с топливным хранилищем, вероятно, из-за недавнего смягчения правил, запрещающих использование буксирных и тяговых нанодронов при строительстве кольца.",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_NANO_EXTEND_3_SPECS": {
