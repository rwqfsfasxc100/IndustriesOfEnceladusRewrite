			"version_hash": 0
		},
		"SYSTEM_HULLVAT_PROP_EXTEND_1": {
			"string": "Расширитель бака рабочего тела",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_PROP_EXTEND_1_DESC": {
			"string": "Стремясь к бесперебойным межпланетным перелётам, Конлиндо разработал это оборудование, позволяющее заменить часть магазина электромагнитных пушек и хранилища компонентов нанодронов, которые не используются при полётах на такие расстояния, чтобы вместить больше топлива в корабль. Несмотря на то, что стандартные межпланетные баки являются минимально необходимыми, дополнительный резерв позволяет пилотам совершать дополнительные манёвры, не рискуя опустошить бак и дрейфовать на протяжении всего пути.",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_PROP_EXTEND_1_SPECS": {
