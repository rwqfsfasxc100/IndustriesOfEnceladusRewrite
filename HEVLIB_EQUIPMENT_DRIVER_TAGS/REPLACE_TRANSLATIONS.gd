			"version_hash": 0
		},
		"SYSTEM_HULLVAT_CONSUMABLESPEED_MANUAL": {
			"string": "Увеличивает скорость поставки соответствующих расходных материалов на определенный процент. \\nНаиболее эффективно использовать в сочетании с промышленным оборудованием.",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_CONSUMABLESPEED_2": {
			"string": "Модуль повышения эффективности подачи расходных материалов Tetsuo RamDrive",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_CONSUMABLESPEED_2_DESC": {
			"string": "В связи с выходом на потребительский рынок электромагнитных пушек промышленного класса Tetsuo HMX 2000l, которые ранее были доступны только для внктреннего использования, потребителям, желающим модернизировать свои суда, чтобы иметь возможность использовать их, особенно для экипажей, которые не могут воспользоваться системой подачи железа или не имеют возможности приобрести судно, отвечающее их требованиям, этот модуль вносит серьезные коррективы в системы доставки на судне и, как следствие, может быть использован для модернизации большинства магазинов, чтобы соответствовать абсурдным требованиям HMX к доставке боеприпасов.",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_CONSUMABLESPEED_2_SPECS": {
			"string": "Скорость доставки расходных материалов: +150% \\nСобственная масса: 9,000 kg \\nПроизводитель: Tetsuo Engineering",
			"version_hash": 0
		},
		"SHIP_YME": {
			"string": "Y-ME Fission Retrofit",
			"version_hash": 0
		},
		"SHIP_YME_SPECS": {
			"string": "Производитель: Злые бывшые работники-Eon Interstellar \\nВысокопрочные подвесы: 1\\nМалопрочные подвесы: 2\\nЭкипаж: 5\\nСухая масса: 34,500 kg \\nОбъём грузового отсека: 140 m^3 \\nХранилище переработанной руды (на каждый тип): 11,000 kg",
			"version_hash": 0
		},
		"SHIP_YME_DESC": {
			"string": "Этот корабль был создан несколькими недовольными сотрудниками Eon Interstellar, которые отделились из-за неэффективного управления компанией как своими сотрудниками, так и отделом по связям с общественностью. Они объединились, чтобы создать более экономически выгодное судно, сделав сияющий корпус EIME более доступным для тех, кто не занимает высокооплачиваемые должности. \\n\\nИз-за особенностей оригинального корпуса EIME пришлось установить специальный реактор с жидкостным барабаном, чего хотели многие конечные пользователи оригинального судна. Для модернизации был использован старый реактор, оставшийся от K37, списанных для строительства жилых зон Энцелада Прайм, поскольку он был в общем распоряжении.",
			"version_hash": 0
		},
		"SYSTEM_REACTOR_EIME_REFIT": {
			"string": "Реактор для замены жидкостного барабана",
			"version_hash": 0
		},
		"SHIP_OCP-SALVAGE": {
			"string": "OCP-209 Спасенный корпус",
			"version_hash": 0
		},
		"SHIP_OCP-SALVAGE_SPECS": {
			"string": "Производитель: Obonto Microengineering\\nМанипуляторы встроенные в отсек: 1\\nВысокопрочные подвесы: 2\\nМалопрочные подвесы: 2\\nЭкипаж: 8\\nСухая масса: 184,500 kg\\nОбъём грузового отсека: да\\nХранилище переработанной руды (общее): 50,000 kg",
			"version_hash": 0
		},
		"SHIP_OCP-SALVAGE_DESC": {
			"string": "Этот корабль был найден в переулке за Sin Space Engineering. Мы спросили, можем ли мы его забрать, но (неоплачиваемый) стажёр, работающий в атриуме, сказал, что ему всё равно, и мы забрали. Весь грузовой отсек был вырезан и заменён манипулятором, как мы полагаем, отчасти для того, чтобы создать конкурента MAD-CERF, а отчасти потому, что Sin Space Engineering не знала, что делать с остальной частью OCP после создания линейки кораблей OK720.",
			"version_hash": 0
		},
		"SHIP_CK65": {
			"string": "CK-65",
			"version_hash": 0
		},
		"SHIP_CK65_SPECS": {
			"string": "Производитель: Conlindo / Rusatom-Antonoff\\nМалопрочные подвесы: 2\\nПодвесы для дронов: 2\\nЭкипаж: 12\\Сухая масса: 82,000 kg \\nОбъём грузового отсека: 40 m^3\\nХранилище переработанной руды (на каждый тип): 37,500 kg",
			"version_hash": 0
		},
		"SHIP_CK65_DESC": {
			"string": "Расцвет переработки полезных ископаемых обусловил потребность в кораблях, способных перевозить значительные объёмы этого сырья для межпланетных перелётов. Столетний опыт создания кораблей класса «Cothon» продемонстрировал жизнеспособность автоматизированных кораблей для путешествий, и «Eagles» были выбраны в качестве судна для завершения нового проекта. Значительная часть грузового отсека была урезана, чтобы разместить шесть гигантских отсеков для хранения обработанных грузов, а также роскошный жилой отсек для 12 пассажиров. Значительная часть оборудования «Орла» была оставлена ​​для удобства капитанов, однако дробилка была заменена стандартным экскаватором для повышения надёжности.",
			"version_hash": 0
		},
		"SHIP_CK69": {
			"string": "CK-69",
			"version_hash": 0
		},
		"SHIP_CK69_SPECS": {
			"string": "Производитель: Conlindo / Rusatom-Antonoff\\nМалопрочные подвесы: 2\\nПодвесы для дронов: 2\\nЭкипаж: 12\\nСухая масса: 102,000 kg \\nОбъём грузового отсека: 40 m^3 \\nХранилище переработанной руды (общее): 200,000 kg",
			"version_hash": 0
		},
		"SHIP_CK69_DESC": {
			"string": "Успех CK-65 привёл к созданию более совершенной модели CK-69, способной обрабатывать любые объёмы руды, но ценой несколько меньшего общего объёма трюма. Он использовался во время спадов производительности на Энцеладе, когда стандартный CK-65 терял место из-за отсутствия определённого минерала. Тем не менее, он был очень популярен среди шахтёров, которые могли надёжнее добывать большие объёмы руды.",
			"version_hash": 0
		},
		"SHIP_PROSPECTOR_RAM": {
			"string": "Prospector RAM",
			"version_hash": 0
		},
		"SHIP_PROSPECTOR_RAM_DESC": {
			"string": "Модификационные решения Ringa Aftermarket приносят в жертву грузовое пространство ради расширения возможностей за счёт использования трофеев и поддельных деталей с различных моделей кораблей. RAM был модифицирован высокопрочными-подвесами от Vulture, электроникой и датчиками от KR-37, хранилищем переработанной руды от Cothon Bender и т. д. Кроме этого также установленно множество оригинальных модификаций. Короткий широкий грузовой отсек, увеличенная грузовая дверь и увеличенная дробилка, усиленная и модернизированная опора руки манипулятора, двигатели и система турелей-резаков, усиленный реактор и т. д. Это достигается за счёт очень большой массы корабля для корабля его размера, уменьшенной вдвое вместимости обрабатываемых ресурсов, уменьшенной вместимости экипажа и чрезвычайно высокой цены. Prospector RAM может справиться с любой ситуацией в кольце, но его большая масса и малая вместимость делают его посредственным горнодобывающим кораблём.",
			"version_hash": 0
		},
		"SHIP_PROSPECTOR_RAM_SPECS": {
			"string": "Производитель: Unknown\\nВысокопрочные подвесы: 1\\nМалопрочные подвесы: 2\\nПодвесы для дронов: 2\\nЭкипаж: 4\\nСухая масса: 54,380 kg\\nХранилище переработанной руды (общее): 40,000 kg\\n Защита от ЭМИ: 200 MW",
			"version_hash": 0
		},
		"SHIP_OCP213_TWIN": {
			"string": "OCP-213 Twin",
			"version_hash": 0
		},
		"SHIP_OCP213_TWIN_SPECS": {
			"string": "Производитель: Obonto Microengineering\\nВысокопрочные подвесы: 2\\nМалопрочные подвесы: 2\\nЭкипаж: 8\\nСухая масса: 187,500 kg\\nОбъём грузового отсека: 610 m^3\\nХранилище переработанной руды (общее): 50,000 kg",
			"version_hash": 0
		},
		"SHIP_OCP213_TWIN_DESC": {
			"string": "Незначительная модификация стандартной модели OCP-209. Twin добавляет второе крепление для горелки и разделяет их в V-образной форме, что позволяет выполнять более разнообразные маневры, особенно при комбинировании перемещения и вращения.",
			"version_hash": 0
		},
		"SHIP_TRTL_PEEPER": {
			"string": "OCK Peeper TNTRL",
			"version_hash": 0
		},
		"SHIP_TRTL_PEEPER_DESC": {
			"string": "Модификация OK720 компании Sin Space Engineering, изготовленная по индивидуальному заказу. Жилой отсек для экипажа перенесён за грузовой отсек для повышения безопасности и снижения вероятности травмирования при горных работах. Необычная форма носовой части корабля значительно смещает узлы подвески относительно центра, однако дополнительные структурные элементы отсека позволяют разместить высокопрочный узел подвески вдоль хребта. \\n\\nВ связи с особенностями изменённого расположения жилого отсека для экипажа между ними установлен большой свинцовый экран радиационной защиты, а также экипажи получают бесплатный препарат Ketron Isoboost в дозе 150 мг в день во время и в течение месяца после полёта на этом судне.",
			"version_hash": 0
		},
		"SHIP_TRTL_PEEPER_SPECS": {
			"string": "Производитель: Conlindo / Obonto Microengineering \\nВысокопрочные подвесы: 1 \\nМалопрочные подвесы: 4 \\nЭкипаж: 4 \\nСухая масса: 101,400 kg \\nОбъём грузового отсека: 600 m^3 \\nХранилище переработанной руды (общее): 25,000 kg",
			"version_hash": 0
		},
		"SYSTEM_AUX_MPD_1400": {
			"string": "OPG-14 StatPlasma",
			"version_hash": 0
		},
		"SYSTEM_AUX_MPD_1400_DESC": {
			"string": "Для экстремальных условий эксплуатации, таких как промышленные печи перерабатывающих заводов, требуется решение с экстремальной мощностью, и StatPlasma от Obonto Microengineering — именно то, что нужно. Энтузиасты и инженеры-электрики (хотя различий мало) называют его «шишкой» из-за необычной винтовой камеры преобразования, которая сужается к выходному отверстию для сбора пара. \\n\\nПримечание: этому устройству может потребоваться небольшой прогрев для достижения полной выходной мощности.",
			"version_hash": 0
		},
		"SYSTEM_AUX_MPD_1400_SPECS": {
			"string": "Энергопотребление: 200 МВт \\nПотребление тепла: 2,5 ГВт \\nМощность (номинальная): 1400 МВт \\nВремя прогрева: 5 с \\nМасса: 12 250 кг \\nТип: МПДГ \\nПроизводитель: Obonto Microengineering",
			"version_hash": 0
		},
		"SYSTEM_AUX_MPD_2000": {
			"string": "MPDG класса MPI City",
			"version_hash": 0
		},
		"SYSTEM_AUX_MPD_2000_DESC": {
			"string": "Этот чудовищный МПДГ буквально не помещается в корпус большинства кораблей, его приходится монтировать снаружи и подключать к нескольким линиям питания. Мощная электростанция для крупных поселений на Марсе и за его пределами. \\n\\nПримечание: этому устройству требуется длительный прогрев, прежде чем оно достигнет полной мощности. MPI настоятельно рекомендует не удалять никакие маркировки, гравировки или другие отметки с устройства.",
			"version_hash": 0
		},
		"SYSTEM_AUX_MPD_2000_SPECS": {
			"string": "Энергопотребление: 300 МВт \\nПотребление тепла: 4 ГВт \\nМощность (номинальная): 2000 МВт \\nВремя прогрева: 15 с \\nМасса: 16 660 кг \\nТип: МПДГ с турбиной-утилизатором \\nПроизводитель: Mars Power Industries",
			"version_hash": 0
		},
		"SYSTEM_AUX_SMES_10K": {
			"string": "Конденсаторная батарея OPS-10",
			"version_hash": 0
		},
		"SYSTEM_AUX_SMES_10K_DESC": {
			"string": "Решение Obonto Microengineering для резервного питания, несмотря на свою неэлегантность, невероятно эффективно. По сути, OPS-10 представляет собой несколько сверхбольших ультраконденсаторов в стальном корпусе, он может обеспечивать феноменальную выходную мощность при пиковой нагрузке, оставаясь при этом примерно таким же доступным, как и стандартные ультраконденсаторы. \\n\\nПоскольку OPS-10 не подключен к внутренним системам охлаждения, для поддержания температуры в нём используются медленная зарядка и громоздкий радиатор.",
			"version_hash": 0
		},
		"SYSTEM_AUX_SMES_10K_SPECS": {
			"string": "Емкость: 10 000 МДж \\nЭнергопотребление: 50 МВт \\nВыходная мощность (пиковая): 10 000 МВт \\nМасса: 6 500 кг \\nТип: Массив фрактальных ультраконденсаторов на основе графена высокой плотности \\nПроизводитель: Obonto Microengineering",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_100": {
			"string": "Лёгкий ультраконденсатор",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_100_DESC": {
			"string": "Фрактальный графеновый цилиндрический ультраконденсатор для хранения избыточной выработанной энергии, обеспечивающий её доступность в периоды пиковой нагрузки. Компактное устройство по разумной цене.",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_100_SPECS": {
			"string": "Емкость: 100 МДж \\nПиковая мощность: 10 ГВт \\nМасса: 400 кг \\nПроизводитель: Obonto Micro Engineering",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_700": {
			"string": "ND-iSMB",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_700_DESC": {
			"string": "Внутренняя сверхпроводящая магнитная батарея Nakamura Dynamics — это альтернативное решение для временного хранения энергии, предложенное после успеха вспомогательной энергетической установки NDAPS. Несмотря на мощную защиту от воздействия плазмы перемассировки, его прямое подключение к электрическим шинам судна обеспечивает максимальную скорость разряда и перезаряда с минимальными потерями.",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_700_SPECS": {
			"string": "Емкость: 700 МДж \\nПиковая мощность: 10 ГВт \\nМасса: 1800 кг \\nПроизводитель: Nakamura Dynamics",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_1400": {
			"string": "Двойная связь ND-iSMB",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_1400_DESC": {
			"string": "Два меньших блока iSMB, соединённых мощным балансиром мощности. Благодаря преднамеренному взаимодействию двух магнитных полей, больше энергии может эффективно храниться в меньшем оборудовании.",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_1400_SPECS": {
			"string": "Емкость: 1400 МДж \\nПиковая мощность: 10 ГВт \\nМасса: 3200 кг \\nПроизводитель: Nakamura Dynamics",
			"version_hash": 0
		},
		"SYSTEM_RODS_1": {
			"string": "1 топливный стержень SO6",
			"version_hash": 0
		},
		"SYSTEM_RODS_1_DESC": {
			"string": "Этот топливный стержень SO6 производства Rusatom-Antonoff, обычно называемый «солнечным осколком», является стандартным топливом для ранних проектов межпланетных ядерных реакторов (ЯТР). В SO6 используется жидкое ядро ​​на основе тория, заключенное в твердую оболочку. Напряжение и состав обеспечивают чрезвычайно высокие рабочие температуры. \\n\\nИдеальный подарок для будущего капитана корабля. Свинцовая упаковка различных дизайнов и цветов доступна по запросу.",
			"version_hash": 0
		},
		"SYSTEM_RODS_1_SPECS": {
			"string": "Производитель: Rusatom-Antonoff \\nРабочая температура: 3,500 K \\nТочка отказа: 4,500 K \\nМасса: 400 kg \\nТеплоотдача: 1 GW",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_20": {
			"string": "Термопарная установка",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_20_DESC": {
			"string": "Эта простая термопарная установка использует тепловой градиент между реактором судна и топливом для выработки электроэнергии. При этом за борт выбрасывается незначительное количество реакционной массы.",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_20_SPECS": {
			"string": "Мощность (номинальная): 20 МВт \\nРасход рабочего тела: 20 г/с \\nМасса: 100 кг \\nПроизводитель: «Rusatom-Antonoff»",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_160": {
			"string": "Ламинарная турбина",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_160_DESC": {
			"string": "Эта энергоустановка для ядерного реактора использует мощь немецкой инженерии (и оптимизированную с помощью искусственного интеллекта конструкцию) для минимизации турбулентности потока и тепловых потерь в четырёхступенчатой ​​рекуперативной турбине.",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_160_SPECS": {
			"string": "Мощность (номинальная): 160 МВт \\nРасход рабочего тела: 160 г/с \\nМасса: 600 кг \\nПроизводитель: Boltzmann Waermerkraftmaschinen",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_320": {
			"string": "Двойная ламинарная турбина",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_320_DESC": {
			"string": "Эта энергоустановка для атомных реакторов использует мощь немецкой инженерии (и оптимизированную с помощью искусственного интеллекта конструкцию) для минимизации турбулентности потока и тепловых потерь в двух четырёхступенчатых регенеративных турбинных узлах. Перераспределение массы и давления между ними осуществляется равномерно благодаря новому твердотельному корпусу клапана.",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_320_SPECS": {
			"string": "Мощность (номинальная): 320 МВт \\nРасход рабочего тела: 320 г/с \\nМасса: 1200 кг \\nПроизводитель: Boltzmann Waermerkraftmaschinen",
			"version_hash": 0
		},
		"SHIP_TSUKUYOMI_IOT": {
			"string": "Фрегат класса «Tsukuyomi» (списанный)",
			"version_hash": 0
		},
		"SHIP_TSUKUYOMI_IOT_DESC": {
			"string": "Лёгкие фрегаты класса «Tsukuyomi» были спроектированы в 2190 году для военных операций по всей Солнечной системе. Они стали первыми в своём классе и заложили основу для современных тактических фрегатов, а их пятиконтурные реакторы служили мощным источником энергии для двигателей. После снятия с вооружения ядерных ракет с солёной водой многие из них были утилизированы или проданы частным военным подрядчикам и корпорациям. \\n\\nБлагодаря верфям Sin Space Engineering этот корабль был полностью демилитаризован и отремонтирован для операций в пределах колец. Его реакторы на солёной воде были заменены тремя модульными защитными оболочками для модернизации установленной современной системы ядерных ракетных двегателей (ЯРД), а носовые торпедные аппараты были разнесены для расширения трюма и добавления четырёх отсеков для вспомогательного оборудования.\\n\\nСтоит отметить, что «Tsukuyomi» по своей конструкции является боевым кораблём, а не грузовым судном. В том же смысле, в каком у фургона больше грузового пространства, чем у танка, поэтому объём его грузового отсека меньше, чем можно было бы ожидать от корабля такого объёма.",
			"version_hash": 0
		},
		"SHIP_TSUKUYOMI_IOT_SPECS": {
			"string": "Производство: Sin Space Engineering / Nakamura Dynamics \\nВысокопрочные подвесы: 1 \\nТорпедные аппараты: 4 \\nСтыковочные отсеки: 4 \\nБашенные установки: 2 \\nЭкипаж: 16 \\nСухая масса: 1655 350 кг \\nОбъем грузового отсека: 1150 м^3 \\nХранилище переработанной руды (на каждый тип): 81 000 кг",
			"version_hash": 0
		},
		"SYSTEM_REACTOR_TSUYUKOMI_IOT-A": {
			"string": "Ядро реактора Tsukuyomi A",
			"version_hash": 0
		},
		"SYSTEM_REACTOR_TSUYUKOMI_IOT-B": {
			"string": "Ядро реактора Tsukuyomi B",
