		},
		"SYSTEM_HULLVAT_CONSUMABLESPEED_MANUAL": {
			"string": "Пришвидшує подачу відповідних витратних матеріалів на певний відсоток. \\nНайкраще працює в поєднанні з обладнанням промислового класу.",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_CONSUMABLESPEED_2": {
			"string": "Tetsuo RamDrive Consumable Delivery Efficiency Module",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_CONSUMABLESPEED_2_DESC": {
			"string": "Разом з випуском на споживчий ринок їхнього промислового мас-драйвера Tetsuo HMX 2000l, модуль, який раніше був доступний лише інсайдерам індустрії, став доступним для споживачів, що бажають модернізувати свої судна для його використання, особливо для екіпажів, які не можуть використовувати його систему подачі заліза або не можуть дозволити собі судно, здатне відповідати його вимогам; цей модуль вносить серйозні корективи в системи доставки судна, і в результаті може бути використаний для модернізації більшості магазинів, дозволяючи їм відповідати абсурдним вимогам HMX щодо подачі боєприпасів.",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_CONSUMABLESPEED_2_SPECS": {
			"string": "Швидкість доставки зі сховища витратних матеріалів: +150% \\nСуха маса: 9,000 кг \\nВиробник: Tetsuo Engineering",
			"version_hash": 0
		},
		"SHIP_YME": {
			"string": "Y-ME Fission Retrofit",
			"version_hash": 0
		},
		"SHIP_YME_SPECS": {
			"string": "Вироблено: Розлючені колишні співробітники Eon Interstellar \\nВисокоміцні кріплення: 1 \\nНизькоміцні кріплення: 2 \\nЕкіпаж: 5 \\nСуха маса: 34,500 кг \\nВантажний відсік: 140 м^3 \\nСклад обробленого вантажу (на мінерал): 11,000 кг",
			"version_hash": 0
		},
		"SHIP_YME_DESC": {
			"string": "Цей корабель створили кілька роздратованих співробітників Eon Interstellar, які пішли з компанії через те, як вона керувала своїми працівниками та піаром. Вони об'єдналися, щоб створити економічно вигідніше судно, зробивши блискучий корпус EIME доступнішим для тих, хто не займає високих посад. \\n\\nЧерез особливості оригінального корпусу EIME він потребував встановлення спеціального рідинного реактора — те, чого багато кінцевих користувачів хотіли бачити в оригінальному судні. Для модернізації було використано старий реактор, що залишився від К37, списаних під час будівництва житлових модулів Енцелад Прайм, оскільки вони були у вільному доступі.",
			"version_hash": 0
		},
		"SYSTEM_REACTOR_EIME_REFIT": {
			"string": "Адаптований рідинний реактор",
			"version_hash": 0
		},
		"SHIP_OCP-SALVAGE": {
			"string": "Відновлений корпус ОБП-209",
			"version_hash": 0
		},
		"SHIP_OCP-SALVAGE_SPECS": {
			"string": "Вироблено: Obonto Microengineering \\nМаніпулятори на місці вантажного відсіку: 1 \\nВисокоміцні кріплення: 2 \\nНизькоміцні кріплення: 2 \\nЕкіпаж: 8 \\nСуха маса: 184,500 кг \\nВантажний відсік: так \\nСклад обробленого вантажу (сукупний): 50,000 кг",
			"version_hash": 0
		},
		"SHIP_OCP-SALVAGE_DESC": {
			"string": "Це судно знайшли в провулку за Sin Space Engineering. Ми запитали, чи можна його забрати, і (неоплачуваний) стажер, що працював в атріумі, сказав, що йому байдуже, тож ми його й забрали. Весь вантажний відсік вирізали і замінили на маніпулятор; ми вважаємо, що це частково для створення конкуренції MAD-CERF, а частково тому, що Sin Space Engineering не знали, що робити з рештою ОБП після випуску лінійки кораблів OK720.",
			"version_hash": 0
		},
		"SHIP_CK65": {
			"string": "CK-65",
			"version_hash": 0
		},
		"SHIP_CK65_SPECS": {
			"string": "Вироблено: Conlindo / Rusatom-Antonoff \\nНизькоміцні кріплення: 2 \\nКріплення дронів: 2 \\nЕкіпаж: 12 \\nСуха маса: 82,000 кг \\nВантажний відсік: 40 м^3 \\nСклад обробленого вантажу (на мінерал): 37,500 кг",
			"version_hash": 0
		},
		"SHIP_CK65_DESC": {
			"string": "Зростання популярності переробників мінералів викликало потребу в кораблях, здатних перевозити значні їх кількості для міжпланетних подорожей. Столітня історія кораблів класу Cothon продемонстрировала життєздатність використання автоматизованих суден для подорожей, і саме Eagle були обрані для реалізації цього нового задуму. \\n\\nЗначну частину його вантажного відсіку випотрошили, щоб встановити 6 гігантських відсіків для зберігання переробленого вантажу, а також розкішні житлові приміщення для розміщення 12 пасажирів. Значну частину обладнання Eagle залишили для зручності капітанів, проте подрібнювач замінили на стандартний екскаватор для забезпечення більшої надійності.",
			"version_hash": 0
		},
		"SHIP_CK69": {
			"string": "CK-69",
			"version_hash": 0
		},
		"SHIP_CK69_SPECS": {
			"string": "Вироблено: Conlindo / Rusatom-Antonoff \\nНизькоміцні кріплення: 2 \\nКріплення дронів: 2 \\nЕкіпаж: 12 \\nСуха маса: 102,000 кг \\nВантажний відсік: 40 м^3 \\nСклад обробленого вантажу (сукупний): 200,000 кг",
			"version_hash": 0
		},
		"SHIP_CK69_DESC": {
			"string": "Успіх CK-65 привів до створення більш досконалого CK-69, здатного працювати з будь-якою кількістю руди, але за рахунок дещо меншої загальної місткості трюму. Він знайшов своє застосування під час спадів пропускної здатності на Енцеладі, коли простір на стандартному CK-65 марнувався б через відсутність певного мінералу, проте став дуже популярним серед шахтарів, які могли надійніше повертатися з великими обсягами руди.",
			"version_hash": 0
		},
		"SHIP_PROSPECTOR_RAM": {
			"string": "Prospector RAM",
			"version_hash": 0
		},
		"SHIP_PROSPECTOR_RAM_DESC": {
			"string": "\"Ringa Aftermarket Modification\" (RAM) жертвує вантажним простором заради розширених можливостей, використовуючи списані та контрафактні деталі від різних моделей кораблів. Модифікація високоміцного кріплення від Vulture, електроніка та сенсори KR-37, змінне сховище перероблених ресурсів від Cothon Bender тощо. \\n\\nRAM також має багато оригінальних модифікацій. Короткий широкий вантажний відсік, більші вантажні двері та більший подрібнювач, посилена та модернізована опора маніпулятора, система маневрових двигунів та турелі, посилений реактор тощо. Все це коштує дуже високої маси для судна такого розміру, зменшеної вдвічі місткості перероблених ресурсів, зменшеного екіпажу та надзвичайно високої ціни. Prospector RAM може впоратися з будь-якою ситуацією в кільці, але його велика маса і низька місткість роблять його посереднім шахтарським судном.",
			"version_hash": 0
		},
		"SHIP_PROSPECTOR_RAM_SPECS": {
			"string": "Виробник: Невідомий \\nВисокоміцні кріплення: 1 \\nНизькоміцні кріплення: 2 \\nКріплення дронів: 2 \\nЕкіпаж: 4 \\nСуха маса: 54,380 кг \\nСклад обробленого вантажу (сукупний): 40,000 кг \\nЗахист від ЕМІ: 200 MW",
			"version_hash": 0
		},
		"SHIP_OCP213_TWIN": {
			"string": "ОБП-213 \"Близнюк\"",
			"version_hash": 0
		},
		"SHIP_OCP213_TWIN_SPECS": {
			"string": "Вироблено: Obonto Microengineering \\nВисокоміцні кріплення: 2 \\nНизькоміцні кріплення: 2 \\nЕкіпаж: 8 \\nСуха маса: 187,500 кг \\nВантажний відсік: 610 м^3 \\nСклад обробленого вантажу (сукупний): 50,000 кг",
			"version_hash": 0
		},
		"SHIP_OCP213_TWIN_DESC": {
			"string": "Незначна модифікація стандартного ОБП-209, \"Близнюк\" додає друге кріплення для головного двигуна і розводить їх у V-подібну форму, що дозволяє виконувати більш різноманітні маневри, особливо при поєднанні переміщення та обертання.",
			"version_hash": 0
		},
		"SHIP_TRTL_PEEPER": {
			"string": "OCK Peeper TNTRL",
			"version_hash": 0
		},
		"SHIP_TRTL_PEEPER_DESC": {
			"string": "Індивідуальна модифікація OK720 від Sin Space Engineering. Житловий модуль екіпажу переміщено за вантажний відсік для безпечнішої експлуатації, щоб удари, спричинені видобутком, відбувалися далі від місць, де вони можуть завдати травм. Нестандартна форма передньої частини судна значно зміщує точки кріплення від центру, проте додаткові структурні елементи на вантажному відсіку дозволяють розмістити високоміцне кріплення вздовж хребта. \\n\\nЧерез особливості переміщеного житлового модуля між ними встановлено великий свинцевий радіаційний щит, а екіпажам надається безкоштовний запас Ketron Isoboost (150 мг на день) під час польоту та протягом місяця після нього.",
			"version_hash": 0
		},
		"SHIP_TRTL_PEEPER_SPECS": {
			"string": "Вироблено: Conlindo / Obonto Microengineering \\nВисокоміцні кріплення: 1 \\nНизькоміцні кріплення: 4 \\nЕкіпаж: 4 \\nСуха маса: 101,400 кг \\nВантажний відсік: 600 м^3 \\nСклад обробленого вантажу (сукупний): 25,000 кг",
			"version_hash": 0
		},
		"SYSTEM_AUX_MPD_1400": {
			"string": "OPG-14 StatPlasma",
			"version_hash": 0
		},
		"SYSTEM_AUX_MPD_1400_DESC": {
			"string": "Екстремальні вимоги до потужності, такі як промислові печі на переробних заводах, вимагають екстремальних рішень, і саме таким рішенням є StatPlasma від Obonto Microengineering. Ентузіасти та інженери-електрики (хоча різниця між ними невелика) називають її \"шишкою\" через її незвичайну гвинтову камеру перетворення, яка звужується до виходу рекуперації. \\n\\nПримітка: цей пристрій може потребувати невеликого періоду прогріву перед досягненням повної потужності.",
			"version_hash": 0
		},
		"SYSTEM_AUX_MPD_1400_SPECS": {
			"string": "Енергоспоживання : 200 MW \\nТеплоспоживання: 2.5 GW \\nПотужність (номінальна): 1,400 MW \\nЧас прогріву: 5 с \\nМаса: 12,250 kg \\nТип: MPDG \\nВиробник: Obonto Microengineering",
			"version_hash": 0
		},
		"SYSTEM_AUX_MPD_2000": {
			"string": "MPDG обласного класу MPI",
			"version_hash": 0
		},
		"SYSTEM_AUX_MPD_2000_DESC": {
			"string": "Цей жахливий MPDG-монстр буквально не може поміститися в корпусі більшості суден, тому його доводиться монтувати зовні і підключати через кілька живильних ліній. Це найкраща електростанція для великих поселень на Марсі та за його межами. Ця установка потребує значного періоду прогрівання перед досягненням максимальної потужності. MPI наполегливо рекомендує не видаляти жодні символи, гравіюри або інші маркування з установки.",
			"version_hash": 0
		},
		"SYSTEM_AUX_MPD_2000_SPECS": {
			"string": "Енергоспоживання : 300 MW \\nТеплоспоживання: 4 GW \\nПотужність (номінальна): 2,000 MW \\nЧас прогріву: 15 с \\nМаса: 16,660 kg \\nТип: MPDG з рекуперативною турбінною установкою \\nВиробник: Mars Power Industries",
			"version_hash": 0
		},
		"SYSTEM_AUX_SMES_10K": {
			"string": "Банк конденсаторів OPS-10",
			"version_hash": 0
		},
		"SYSTEM_AUX_SMES_10K_DESC": {
			"string": "Резервне джерело живлення від Obonto Microengineering є, хоч і неелегантним, але надзвичайно ефективним рішенням. Фактично це кілька надвеликих ультраконденсаторів у сталевому корпусі. OPS-10 може забезпечувати феноменальну вихідну потужність при пікових навантаженнях, залишаючись при цьому настільки ж доступним, як і їхній стандартний асортимент ультраконденсаторів. \\n\\nЧерез те, що він не підключений до внутрішніх систем охолодження, OPS-10 покладається на повільну швидкість зарядки та громіздкий радіаційний охолоджувач для управління температурою.",
			"version_hash": 0
		},
		"SYSTEM_AUX_SMES_10K_SPECS": {
			"string": "Ємність: 10,000 MJ \\nЕнергоспоживання: 50 MW \\nВихідна потужніть (пікова): 10,000 MW \\nМаса: 6,500 kg \\nТип: Масив високощільних графенових фрактальних ультраконденсаторів \\nВиробник: Obonto Microengineering",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_100": {
			"string": "Легкий ультраконденсатор",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_100_DESC": {
			"string": "Графеновий фрактальний ультраконденсаторний циліндр для зберігання надлишкової енергії, що генерується, для доступності під час пікових навантажень. Компактний пристрій за розумною ціною.",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_100_SPECS": {
			"string": "Ємність: 100 MJ \\nПікова віддача: 10 GW \\nМаса: 400 кг  \\nВиробник: Obonto Micro Engineering",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_700": {
			"string": "ND-iSMB",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_700_DESC": {
			"string": "Внутрішня надпровідна магнітна батарея від Nakamura Dynamics є альтернативним тимчасовим рішенням для зберігання енергії, запропонованим після успіху допоміжного енергоблоку NDAPS. Хоча батарея сильно екранована для запобігання впливу плазми реактивної маси на поле, її прямий інтерфейс з електричними шинами судна дозволяє досягати максимальних швидкостей розряду та зарядки з мінімальними втратами.",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_700_SPECS": {
			"string": "Ємність: 700 MJ \\nПікова віддача: 10 GW \\nМаса: 1,800 кг \\nВиробник: Nakamura Dynamics",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_1400": {
			"string": "Здвоєний ND-iSMB",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_1400_DESC": {
			"string": "Два менших блоки iSMB, з'єднані за допомогою потужного балансувальника енергії. Завдяки цілеспрямованому допущенню взаємодій між двома магнітними полями, можна ефективніше зберігати більше енергії в меншому обладнанні.",
			"version_hash": 0
		},
		"SYSTEM_CAPACITOR_1400_SPECS": {
			"string": "Ємність: 1,400 MJ \\nПікова віддача: 10 GW \\nМаса: 3,200 кг \\nВиробник: Nakamura Dynamics",
			"version_hash": 0
		},
		"SYSTEM_RODS_1": {
			"string": "1 паливний стрижень SO6",
			"version_hash": 0
		},
		"SYSTEM_RODS_1_DESC": {
			"string": "Цей ядерний паливний стрижень Rusatom-Antonoff SO6, зазвичай званий \"сонячним променем\", є стандартним паливом для ранніх міжпланетних НТР-дизайнів. SO6 використовує рідкий торієвий сердечник, укладений у тверду оболонку. Напруження і склад забезпечують надзвичайно високі робочі температури. \\n\\nІдеальний подарунок для майбутнього капітана корабля. Свинцевий обгортковий матеріал у різноманітних дизайнах та кольорах доступний за запитом.",
			"version_hash": 0
		},
		"SYSTEM_RODS_1_SPECS": {
			"string": "Виробник: Rusatom-Antonoff \\nРобоча температура: 3,500 K \\nТочка відмови: 4,500 K \\nМаса: 400 кг \\nТепловіддача: 1 GW",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_20": {
			"string": "Масив термопар",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_20_DESC": {
			"string": "Цей простий масив термопар використовує тепловий градієнт між реактором судна і робочим тілом для генерації електроенергії. В процесі незначна кількість реакційної маси викидається за борт.",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_20_SPECS": {
			"string": "Потужність (номінальна): 20 MW \\nСпоживання робочої маси: 20 г/с \\nМаса: 100 кг \\nВиробник: Rusatom-Antonoff",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_160": {
			"string": "Ламінарна турбіна",
			"version_hash": 0
		},
		"SYSTEM_TURBINE_160_DESC": {
