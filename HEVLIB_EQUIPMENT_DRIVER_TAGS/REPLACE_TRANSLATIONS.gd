		"SYSTEM_HULLVAT_PROP_1_DESC": {
			"string": "Эти меньшие по размеру комплекты расширителей, созданные на основе исследований компании Conlindo в области динамических расширителей топливных баков, предназначены для бригад, занимающихся исследованиями, поисково-спасательными работами или строительством, поскольку в них остается много свободного пространства, остающегося после неиспользования обработанных хранилищ, и часть из них можно повторно использовать для размещения рабочего тела.",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_PROP_1_SPECS": {
			"string": "Вместимость топлива: 10,000 kg \\nУменьшение хранилища переработанных минералов: 10% \\nСобственная масса: 1,500 kg \\nПроизводитель: Conlindo RVM",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_PROP_MANUAL": {
			"string": "Дополнительное рабочее тело для двигателей и турбин. \\nРабочее тело продаётся отдельно в начале полета. \\nДисплеи датчиков HUD могут отображать новые значения правильно или неправильно.",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_PROP_2": {
			"string": "Бак с топливом Mk. II",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_PROP_2_DESC": {
			"string": "Представляя собой современное усовершенствование по сравнению с Mk. I, этот комплект использует более эффективные методы хранения, позволяя занимать меньше места на килограмм веса, чем его предшественник. Этот комплект всё ещё может оказаться не самым эффективным для некоторых экипажей, поскольку значительно более тяжёлая рама отпугнула некоторых капитанов, оценив его преимущества.",
			"version_hash": 0
