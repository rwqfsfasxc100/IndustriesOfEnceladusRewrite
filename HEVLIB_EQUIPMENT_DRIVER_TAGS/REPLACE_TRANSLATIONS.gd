		"SYSTEM_HULLVAT_NANO_1": {
			"string": "Runasimi Drone Component Vat",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_NANO_1_DESC": {
			"string": "Как и многие коммерческие продукты Runasimi, DCV ориентирован на небольшое расширение имеющихся компонентов нанодрона. Изначально разработанный как резервный отсек, доступный только в чрезвычайных ситуациях, более поздние модели были разблокированы, чтобы их содержимое можно было использовать во время обычного полёта.",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_NANO_1_SPECS": {
			"string": "Хранилище нанодронов: 6,000 kg \\nУменьшение боезапаса: 25% \\nСобственная масса: 4,500 kg \\nПроизводитель: Runasimi ",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_NANO_MANUAL": {
			"string": "Дополнительные детали для сборки нанодронов. Совместимы со всеми пусковыми установками для дронов. \\nСкорость доставки деталей дрона зависит от установленного магазина. \\nКомпоненты дронов продаются отдельно на старте полета. \\nДисплеи датчиков HUD могут отображать новые значения корректно или нет.",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_NANO_2": {
			"string": "Runasimi Hull-Fitted Nanodrone Locker",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_NANO_2_DESC": {
			"string": "Благодаря успеху DCV было запущено в производство более крупное устройство, позволяющее пользователям, использующим нанодроны в больших количествах, эффективно использовать часто неиспользуемое пространство магазинов электромагнитных пушек, что позволило разместить значительно большую часть нанодронов. Отсутствие специальных предохранительных устройств позволило увеличить соотношение размеров деталей к пространству магазина по сравнению с предыдущими конструкциями.",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_NANO_2_SPECS": {
			"string": "Хранилище нанодронов: 15,000 kg \\nУменьшение боезапаса: 50% \\nСобственная масса: 12,000 kg \\nПроизводитель: Runasimi",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_NANO_EXTEND_1": {
			"string": "Antonoff Nano Storage Expansion",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_NANO_EXTEND_1_DESC": {
			"string": "Эта модификация, основанная на конструкции, аналогичной линейке боеприпасов в расширенных комплектах модернизации, заменяет часть трюма для минералов, позволяя хранить больше деталей нанодрона внутри судна. Обратите внимание, что к этим комплектам применяются те же законы, а допустимые отклонения в хранении привязаны к маркировке независимо от судна.",
			"version_hash": 0
		},
		"SYSTEM_HULLVAT_NANO_EXTEND_1_SPECS": {
			"string": "Модификатор вместимости хранилища нанодронов: +33% \\nХранилище нанодронов: 1,000 kg \\nУменьшение хранилища переработанных минералов: 10% \\nСобственная масса: 10,500 kg \\nПроизводитель: Antonoff",
